@model IEnumerable<ProyectoDuolingoC_.Models.CursoProgresoVM>

@{
    ViewData["Title"] = "Mis Cursos";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --forest-base: #1a4332;
        --forest-accent: #2d6a4f;
        --soft-gray: #f8f9fa;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: #f4f4f4;
    }

    /* --- CABECERA (HERO) --- */
    .header-hero {
        background: var(--forest-base);
        border-radius: 30px;
        padding: 4rem 2rem;
        color: white;
        text-align: center;
        margin-bottom: 3rem;
        box-shadow: 0 15px 35px rgba(26, 67, 50, 0.2);
    }

        .header-hero h1 {
            font-weight: 900;
            font-size: 3rem;
            margin-bottom: 1rem;
        }

    /* --- BUSCADOR --- */
    .search-container {
        max-width: 600px;
        margin: -55px auto 3rem;
    }

    .search-bar {
        background: white;
        border-radius: 20px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border: 2px solid transparent;
        transition: 0.3s;
    }

        .search-bar:focus-within {
            border-color: var(--forest-accent);
        }

        .search-bar input {
            border: none;
            width: 100%;
            margin-left: 10px;
            font-weight: 600;
            outline: none;
        }

    /* --- TARJETAS --- */
    .course-card {
        background: white;
        border-radius: 25px;
        padding: 2rem;
        border: none;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        border-bottom: 5px solid #e9ecef;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-bottom-color: var(--forest-accent);
        }

    .course-badge {
        background: #f0f7f4;
        color: var(--forest-base);
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 1rem;
    }

    /* --- BARRA DE PROGRESO --- */
    .progress-container {
        width: 100%;
        height: 8px;
        background-color: #e9ecef;
        border-radius: 10px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background-color: var(--forest-accent);
        border-radius: 10px;
        transition: width 0.5s ease-in-out;
    }

    /* --- BOTÓN ACCIÓN --- */
    .btn-action {
        background: var(--forest-base);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 0.8rem;
        font-weight: 700;
        width: 100%;
        margin-top: auto;
        text-decoration: none;
        display: block;
        text-align: center;
        transition: 0.3s;
    }

        .btn-action:hover {
            background: var(--forest-accent);
            color: white;
            transform: scale(1.02);
        }


    /* Corrección para Responsive en Razor (usar doble @@) */
    @@media (max-width: 768px) {
        .header-hero h1 {
            font-size: 2rem;
        }

        .course-card {
            padding: 1.5rem;
        }
    }
</style>

<div class="header-hero">
    <h1>Mis Cursos</h1>
    <p class="opacity-75 lead">Sigue avanzando en tu ruta de aprendizaje. ¡Tú puedes!</p>
</div>

<div class="search-container">
    <div class="search-bar">
        <i class="bi bi-search text-muted"></i>
        <input type="text" id="filterInput" placeholder="Busca entre tus cursos activos...">
    </div>
</div>

<div class="row g-4" id="courseGrid">
    @if (Model != null && Model.Any())
    {
        @foreach (var curso in Model)
        {
            <div class="col-md-6 col-lg-4 course-item">
                <div class="course-card">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="course-badge">@curso.EtiquetaLenguaje</span>
                        <i class="bi bi-journal-code text-muted"></i>
                    </div>

                    <h3 class="fw-bold h4 mb-3">@curso.Titulo</h3>

                    <p class="text-muted small mb-3">
                        @(curso.Descripcion?.Length > 90 ? curso.Descripcion.Substring(0, 90) + "..." : curso.Descripcion)
                    </p>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between text-muted small fw-bold mb-1">
                            <span>Progreso</span>
                            <span>@curso.PorcentajeProgreso%</span>
                        </div>
                        <div class="progress-container">
                            <div class="progress-bar-fill" style="width: @curso.PorcentajeProgreso%;"></div>
                        </div>
                    </div>

                    <a asp-action="ContinuarAvanzando" asp-controller="Cursos" asp-route-idCurso="@curso.CursoID" class="btn-action">
                        CONTINUAR <i class="bi bi-arrow-right-short ms-1 fs-5 align-middle"></i>
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-journal-x fs-1 text-muted" style="font-size: 5rem !important;"></i>
            <h3 class="fw-bold mt-4" style="color: var(--forest-base);">Aún no tienes cursos</h3>
            <p class="text-muted mt-2 mb-4">Parece que todavía no te has inscrito en ninguna de nuestras rutas de aprendizaje.</p>

            <a asp-action="Index" asp-controller="Cursos" class="btn btn-outline-success fw-bold px-4 py-2" style="border-radius: 20px; border-width: 2px;">
                Explorar Catálogo
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Buscador interactivo sin recarga
        document.getElementById('filterInput').addEventListener('input', function () {
            let filter = this.value.toLowerCase();
            let items = document.querySelectorAll('.course-item');

            items.forEach(item => {
                let text = item.innerText.toLowerCase();
                item.style.display = text.includes(filter) ? "block" : "none";
            });
        });
    </script>
}
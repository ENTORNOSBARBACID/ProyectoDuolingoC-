@model ProyectoDuolingoC_.Models.Curso

@{
    ViewData["Title"] = "Curso de " + Model.Titulo;
    List<Leccion> lecciones = ViewData["LECCIONES"] as List<Leccion>;

    // 1. Lógica para la imagen de fondo:
    string backgroundUrl = "";
    bool tieneImagen = Model.Imagen != null && Model.Imagen.Length > 0;

    if (tieneImagen)
    {
        // Convertimos el array de bytes a una cadena Base64 válida para CSS
        string base64Image = Convert.ToBase64String(Model.Imagen);
        backgroundUrl = $"url('data:image/jpeg;base64,{base64Image}')";
    }
    else
    {
        // Si no tiene imagen, ponemos un gradiente sólido de tu verde bosque
        backgroundUrl = "linear-gradient(to right, #1a4332, #2d6a4f)";
    }
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;600;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332;
        --f-accent: #58cc02;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: #fdfdfd;
    }

    /* --- HERO CON IMAGEN DINÁMICA --- */
    .hero-full {
        position: relative;
        min-height: 400px;
        /* ¡Aquí aplicamos la lógica de la variable backgroundUrl! */
        @if (tieneImagen)
        {
            <text> background-image: linear-gradient(to right, rgba(26, 67, 50, 0.95) 30%, rgba(26, 67, 50, 0.4) 100%), @Html.Raw(backgroundUrl);
            </text>
        }
        else
        {

            <text> background-image: @Html.Raw(backgroundUrl);
            </text>
        }
        background-size: cover;
        background-position: center;
        border-radius: 0 0 60px 60px;
        display: flex;
        align-items: center;
        color: white;
        margin-top: -2rem;
        padding-bottom: 4rem;
    }

    .btn-return {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 2rem;
        font-weight: 500;
        transition: 0.3s;
    }

        .btn-return:hover {
            color: white;
            transform: translateX(-5px);
        }

    /* --- CONTENEDOR DE CONTENIDO --- */
    .overlap-content {
        margin-top: -6rem;
        position: relative;
        z-index: 10;
    }

    /* Sidebar Flotante */
    .enroll-card {
        background: white;
        border-radius: 28px; /* Un poco menos exagerado para que se vea más profesional */
        padding: 2.5rem;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05), 0 5px 15px rgba(0,0,0,0.03);
        border: 1px solid #f0f0f0;
        position: sticky;
        top: 20px;
        transition: box-shadow 0.3s ease;
    }

        /* Efecto sutil: cuando pasas el ratón por la tarjeta, se eleva un poco */
        .enroll-card:hover {
            box-shadow: 0 25px 50px rgba(0,0,0,0.08);
        }

    .btn-enroll-now {
        background: var(--f-dark);
        color: white;
        border: none;
        border-radius: 18px;
        padding: 1.2rem 1rem; /* Reducimos un poco el padding lateral si es necesario */
        font-size: 1rem; /* Ajustamos el tamaño para que quepa bien */
        font-weight: 800;
        width: 100%;
        /* --- LA MAGIA ESTÁ AQUÍ --- */
        white-space: nowrap; /* Evita que el texto salte de línea */
        display: flex; /* Centrado perfecto */
        align-items: center;
        justify-content: center;
        /* -------------------------- */

        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 20px rgba(26, 67, 50, 0.25);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        text-decoration: none;
    }

        .btn-enroll-now:hover {
            transform: scale(1.02) translateY(-3px);
            filter: brightness(1.2);
            color: white;
            box-shadow: 0 12px 25px rgba(26, 67, 50, 0.35);
        }

        /* Estado activo (cuando haces clic) */
        .btn-enroll-now:active {
            transform: scale(0.98) translateY(0);
        }

    /* --- LISTA DE LECCIONES --- */
    .lesson-box {
        background: white;
        border-radius: 35px;
        padding: 3rem;
        border: 1px solid #f0f0f0;
    }

    .lesson-strip, .lesson-strip-disabled {
        display: flex;
        align-items: center;
        padding: 1.5rem;
        background: #fcfdfc;
        border-radius: 20px;
        margin-bottom: 1rem;
        text-decoration: none;
        color: inherit;
        border: 1.5px solid #f0f0f0;
        transition: 0.3s;
    }

        .lesson-strip:hover {
            border-color: var(--f-dark);
            background: #f8fbf9;
            transform: translateX(10px);
        }

    .lesson-strip-disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

        .lesson-strip-disabled:hover {
            border-color: red;
            background: #fffafa; /* Un fondo rojizo muy sutil en lugar del verde */
            transform: translateX(10px);
        }

    /* --- ESTILOS PARA LECCIÓN COMPLETADA --- */
    .lesson-strip.lesson-completed {
        /* Usamos un color sólido para evitar que el texto se vea borroso */
        background-color: #f1f4f2 !important;
        border-left: 6px solid #1a4332 !important;
        border-right: 1px solid #d1d9d4 !important;
        border-top: 1px solid #d1d9d4 !important;
        border-bottom: 1px solid #d1d9d4 !important;
        transition: all 0.2s ease;
    }

        /* Forzamos que el hover se note incluso en las completadas */
        .lesson-strip.lesson-completed:hover {
            background-color: #e6ede9 !important; /* Un verde un pelín más oscuro al pasar el ratón */
            transform: translateX(5px); /* Efecto de desplazamiento lateral */
            box-shadow: 0 4px 12px rgba(26, 67, 50, 0.1);
        }

    /* El círculo del check bien definido */
    .lesson-completed .lesson-idx {
        background-color: #1a4332 !important;
        color: white !important;
        border: none !important;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    /* Título nítido */
    .lesson-completed h6 {
        color: #1a4332 !important;
        font-weight: 700 !important;
    }
    /* --- AÑADIR LECCIÓN --- */
    .lesson-strip-add {
        display: flex;
        align-items: center;
        padding: 1.5rem;
        background: transparent;
        border-radius: 20px;
        margin-bottom: 1rem;
        text-decoration: none;
        color: #6c757d;
        border: 2px dashed #d1d5db;
        transition: 0.3s;
        justify-content: center;
    }

        .lesson-strip-add:hover {
            background: white;
            border-color: var(--f-accent);
            color: var(--f-accent);
            transform: scale(1.02);
        }

    .lesson-idx {
        width: 45px;
        height: 45px;
        background: #f0f7f1;
        color: var(--f-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin-right: 1.5rem;
    }

    @@media (max-width: 991px) {
        .overlap-content {
            margin-top: 2rem;
        }

        .hero-full {
            border-radius: 0;
            min-height: 300px;
        }
    }
</style>

<div class="hero-full animate__animated animate__fadeIn">
    <div class="container">
        <a asp-action="Index" asp-controller="Home" class="btn-return">
            <i class="bi bi-arrow-left-short fs-4"></i> Volver a Cursos
        </a>
        <div class="col-lg-7">
            <h1 class="display-3 fw-bold animate__animated animate__fadeInUp">@Model.Titulo</h1>
            <p class="lead opacity-75 animate__animated animate__fadeInUp" style="animation-delay: 0.2s">
                Descubre una nueva forma de aprender con nuestra metodología inmersiva.
            </p>
        </div>
    </div>
</div>

<div class="container overlap-content">
    <div class="row g-5">

        <div class="col-lg-8">
            <div class="lesson-box shadow-sm animate__animated animate__fadeInUp" style="animation-delay: 0.3s">
                <h4 class="fw-bold mb-4">Descripción del Programa</h4>
                <p class="text-muted mb-5" style="line-height: 1.8; font-size: 1.05rem;">
                    @Model.Descripcion
                </p>

                <h4 class="fw-bold mb-4">Plan de Estudios</h4>

                @if (lecciones != null && lecciones.Any())
                {
                    int idx = 1;
                    foreach (var leccion in lecciones)
                    {
                        @if (ViewData["CURSO"] is false && ViewData["LECCION"] != null && leccion.Orden <= (int)ViewData["LECCION"])
                        {
                            // Determinamos si la lección está completada
                            // (Según tu lógica: si el orden es MENOR al progreso actual del usuario)
                            bool estaCompletada = leccion.Orden < (int)ViewData["LECCION"];
                            string claseCompletada = estaCompletada ? "lesson-completed" : "";

                            <div class="lesson-strip animate__animated animate__fadeInLeft d-flex align-items-center pe-3 @claseCompletada"
                                 style="animation-delay: @(0.4 + (idx * 0.1))s">

                                <a asp-action="Index" asp-controller="Lecciones" asp-route-id="@leccion.LeccionID"
                                   class="d-flex align-items-center flex-grow-1 text-decoration-none text-dark">

                                    <div class="lesson-idx d-flex align-items-center justify-content-center shadow-sm">
                                        @if (estaCompletada)
                                        {
                                            <i class="bi bi-check-lg fs-5"></i>
                                        }
                                        else
                                        {
                                            @idx
                                        }
                                    </div>

                                    <div>
                                        <h6 class="mb-0 fw-bold">@leccion.Titulo</h6>
                                        <small class="text-muted">
                                            @if (estaCompletada)
                                            {
                                                <span class="text-success fw-bold"><i class="bi bi-patch-check-fill me-1"></i>¡Completado!</span>
                                            }
                                            else
                                            {
                                                @:Módulo de aprendizaje • 20-40 min
                                            }
                                        </small>
                                    </div>
                                </a>

                                @if (Context.User.FindFirst(ClaimTypes.Role)?.Value == "2")
                                {
                                    <div class="lesson-actions ms-auto d-flex gap-2">
                                        <a asp-action="Edit" asp-controller="Lecciones" asp-route-id="@leccion.LeccionID"
                                           class="btn btn-sm btn-outline-primary" style="border-radius: 10px;" title="Editar Lección">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius: 10px;" title="Eliminar Lección"
                                                onclick="confirmarEliminarLeccion(@leccion.LeccionID, '@leccion.Titulo', @leccion.CursoID)">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        else 
                        {
                            <div class="lesson-strip-disabled animate__animated animate__fadeInLeft" style="animation-delay: @(0.4 + (idx * 0.1))s">
                                <div class="lesson-idx" style="background: #f1f3f5; color: #adb5bd;">@idx</div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold text-muted">@leccion.Titulo</h6>
                                    <small class="text-muted"><i class="bi bi-lock-fill"></i> Bloqueado • 20-40 min</small>
                                </div>
                            </div>
                        }
                        idx++;
                    }
                }
                else
                {
                    <p class="text-muted mb-4"><i class="bi bi-info-circle me-2"></i>Aún no hay lecciones creadas para este curso.</p>
                }
                @if (Context.User.FindFirst(ClaimTypes.Role).Value == "2")
                {
                    
                    <a asp-action="Create" asp-controller="Lecciones" asp-route-id="@Model.CursoID" class="lesson-strip-add mt-4">
                        <i class="bi bi-plus-circle me-2 fs-4"></i>
                        <h6 class="mb-0 fw-bold">Añadir nueva lección</h6>
                    </a>
                }

            </div>
        </div>

        <div class="col-lg-4">
            <div class="enroll-card animate__animated animate__fadeInRight" style="animation-delay: 0.5s">
                <h3 class="fw-bold mb-3">Empieza Hoy</h3>

                <div class="mb-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-check-lg text-success me-2"></i>
                        <span class="small fw-bold">Acceso ilimitado</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-check-lg text-success me-2"></i>
                        <span class="small fw-bold">Certificado de experto</span>
                    </div>
                </div>

                @if (ViewData["CURSO"] is true)
                {
                    <a asp-controller="Cursos" asp-action="Inscribirse" asp-route-id="@Model.CursoID" class="btn-enroll-now">
                            Inscribirme Ahora
                    </a>
                }
                else
                {
                    <button type="button" class="btn-enroll-now" style="background-color: #e9ecef; color: #6c757d; box-shadow: none; cursor: default;" disabled>
                        <i class="bi bi-check-circle-fill me-2"></i> Estás Apuntado
                    </button>
                }

                @if (TempData["SUCCESS"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show animate__animated animate__bounceIn mt-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SUCCESS"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <p class="text-center mt-3 small text-muted">
                    Únete a más de 1,200 alumnos registrados.
                </p>
            </div>
        </div>

    </div>
</div>

<div class="py-5"></div>

@section Scripts {
    <script>
        function confirmarEliminarLeccion(idLeccion, tituloLeccion, idCurso) {
        Swal.fire({
            title: '¿Borrar lección?',
            html: `Vas a eliminar la lección <b>${tituloLeccion}</b> de forma permanente.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                // Cambia "Lecciones" y "Eliminar" por los nombres de tu controlador y acción reales
                    window.location.href = `/Lecciones/Eliminar?id=${idLeccion}&idCurso=${idCurso}`;
            }
        })
    }
    </script>
}
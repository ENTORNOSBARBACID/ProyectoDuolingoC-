@model ProyectoDuolingoC_.Models.Curso

@{
    ViewData["Title"] = "Curso de " + Model.Titulo;
    List<Leccion> lecciones = ViewData["LECCIONES"] as List<Leccion>; 
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;600;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332;
        --f-accent: #58cc02;
    }

    body { 
        font-family: 'Outfit', sans-serif; 
        background-color: #fdfdfd; 
    }

    /* --- HERO CON IMAGEN DINÁMICA --- */
    .hero-full {
        position: relative;
        min-height: 400px;
        background-image: linear-gradient(to right, rgba(26, 67, 50, 0.95) 30%, rgba(26, 67, 50, 0.4) 100%), url('@Model.Imagen');
        background-size: cover;
        background-position: center;
        border-radius: 0 0 60px 60px;
        display: flex;
        align-items: center;
        color: white;
        margin-top: -2rem;
        padding-bottom: 4rem;
    }

    .btn-return {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 2rem;
        font-weight: 500;
        transition: 0.3s;
    }

    .btn-return:hover { color: white; transform: translateX(-5px); }

    /* --- CONTENEDOR DE CONTENIDO --- */
    .overlap-content { margin-top: -6rem; position: relative; z-index: 10; }

    /* Sidebar Flotante */
    .enroll-card {
        background: white;
        border-radius: 35px;
        padding: 2.5rem;
        box-shadow: 0 25px 50px rgba(0,0,0,0.1);
        border: 1px solid #eee;
        position: sticky;
        top: 20px;
    }

    .btn-enroll-now {
        background: var(--f-accent);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-weight: 900;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 10px 20px rgba(88, 204, 2, 0.3);
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }


    .btn-enroll-now:hover {
        transform: scale(1.03) translateY(-5px);
        filter: brightness(1.1);
        color: white;
    }

    /* --- LISTA DE LECCIONES --- */
    .lesson-box {
        background: white;
        border-radius: 35px;
        padding: 3rem;
        border: 1px solid #f0f0f0;
    }

    .lesson-strip {
        display: flex;
        align-items: center;
        padding: 1.5rem;
        background: #fcfdfc;
        border-radius: 20px;
        margin-bottom: 1rem;
        text-decoration: none;
        color: inherit;
        border: 1px solid #f0f0f0;
        transition: 0.3s;
    }

    .lesson-strip:hover {
        border-color: var(--f-accent);
        background: #f8fbf9;
        transform: translateX(10px);
    }

    .lesson-idx {
        width: 45px;
        height: 45px;
        background: #f0f7f1;
        color: var(--f-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin-right: 1.5rem;
    }

    @@media (max-width: 991px) {
        .overlap-content { margin-top: 2rem; }
        .hero-full { border-radius: 0; min-height: 300px; }
    }
</style>

<div class="hero-full animate__animated animate__fadeIn">
    <div class="container">
        <a asp-action="Index" asp-controller="Home" class="btn-return">
            <i class="bi bi-arrow-left-short fs-4"></i> Volver a Cursos
        </a>
        <div class="col-lg-7">
            <h1 class="display-3 fw-bold animate__animated animate__fadeInUp">@Model.Titulo</h1>
            <p class="lead opacity-75 animate__animated animate__fadeInUp" style="animation-delay: 0.2s">
                Descubre una nueva forma de aprender con nuestra metodología inmersiva.
            </p>
        </div>
    </div>
</div>



<div class="container overlap-content">
    <div class="row g-5">
        
        <div class="col-lg-8">
            <div class="lesson-box shadow-sm animate__animated animate__fadeInUp" style="animation-delay: 0.3s">
                <h4 class="fw-bold mb-4">Descripción del Programa</h4>
                <p class="text-muted mb-5" style="line-height: 1.8; font-size: 1.05rem;">
                    @Model.Descripcion
                </p>

                <h4 class="fw-bold mb-4">Plan de Estudios</h4>
                @if(ViewData["CURSO"] is false)
                {
                    @if (lecciones != null )
                    {
                        int idx = 1;
                        foreach (var leccion in lecciones)
                        {
                            <a asp-action="Index" asp-controller="Lecciones" asp-route-id="@leccion.LeccionID" class="lesson-strip animate__animated animate__fadeInLeft" 
                               style="animation-delay: @(0.4 + (idx * 0.1))s">
                                <div class="lesson-idx">@idx</div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold">@leccion.Titulo</h6>
                                    <small class="text-muted">Módulo de aprendizaje • 20-40 min</small>
                                </div>
                            </a>
                            idx++;
                        }
                    }
                }
                else
                {
                    @if (lecciones != null)
                    {
                        int idx = 1;
                        foreach (var leccion in lecciones)
                        {
                            <a class="lesson-strip animate__animated animate__fadeInLeft"
                               style="animation-delay: @(0.4 + (idx * 0.1))s">
                                <div class="lesson-idx">@idx</div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold">@leccion.Titulo</h6>
                                    <small class="text-muted">Módulo de aprendizaje • 20-40 min</small>
                                </div>
                            </a>
                            idx++;
                        }
                    }
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="enroll-card animate__animated animate__fadeInRight" style="animation-delay: 0.5s">
                <h3 class="fw-bold mb-3">Empieza Hoy</h3>
                
                <div class="mb-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-check-lg text-success me-2"></i>
                        <span class="small fw-bold">Acceso ilimitado</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-check-lg text-success me-2"></i>
                        <span class="small fw-bold">Certificado de experto</span>
                    </div>
                </div>
                @if(ViewData["CURSO"] is true)
                {
                <form asp-controller="Cursos" asp-action="Inscribirse" asp-route-id = "@Model.CursoID" method="post">
                    <input type="hidden" name="cursoId" value="@Model.CursoID" />
                    <button type="submit" class="btn-enroll-now">
                        Inscribirme Ahora
                    </button>
                </form>
                }
                else
                {
                    <form asp-controller="Lecciones" asp-action="VerLecciones" asp-route-id="@Model.CursoID" method="post">
                        <input type="hidden" name="cursoId" value="@Model.CursoID" />
                        <button type="submit" class="btn-enroll-now">
                            Ver Curso
                        </button>
                    </form>
                }
                @if (TempData["SUCCESS"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show animate__animated animate__bounceIn" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SUCCESS"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                
                <p class="text-center mt-3 small text-muted">
                    Únete a más de 1,200 alumnos registrados.
                </p>
            </div>
        </div>

    </div>
</div>

<div class="py-5"></div>

@section Scripts {

    
}

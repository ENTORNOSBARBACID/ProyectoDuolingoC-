@* Asumo que le pasarás una lista de un ViewModel que contenga al estudiante y sus cursos. 
   Ajusta el nombre del modelo al que tengas creado *@
@model IEnumerable<ProyectoDuolingoC_.Models.EstudianteAdminVM>

@{
    ViewData["Title"] = "Gestión de Estudiantes";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --forest-base: #1a4332;
        --forest-accent: #2d6a4f;
        --soft-bg: #f8f9fa;
        --border-color: #e5e5e5;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--soft-bg);
    }

    .admin-header {
        background: var(--forest-base);
        color: white;
        padding: 3rem 2rem;
        border-radius: 20px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 20px rgba(26, 67, 50, 0.15);
    }

    /* Estilos del Acordeón personalizado */
    .custom-accordion .accordion-item {
        border: none;
        border-radius: 15px;
        margin-bottom: 1rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .custom-accordion .accordion-button {
        background-color: white;
        padding: 1rem 1.5rem;
        font-weight: 600;
        color: #333;
        box-shadow: none !important;
    }

    .custom-accordion .accordion-button:not(.collapsed) {
        background-color: #eef3f0;
        color: var(--forest-base);
    }

    .student-avatar {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid var(--forest-accent);
    }

    /* Estilos de la lista de cursos interna */
    .course-list-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
        transition: 0.2s;
    }

    .course-list-item:last-child {
        border-bottom: none;
    }

    .course-list-item:hover {
        background-color: #fcfcfc;
    }

    .progress-mini {
        height: 8px;
        width: 120px;
        background-color: #e9ecef;
        border-radius: 10px;
        overflow: hidden;
        margin-top: 5px;
    }

    .progress-mini-fill {
        height: 100%;
        background-color: var(--forest-accent);
    }

    .btn-remove {
        background-color: #fff;
        color: #dc3545;
        border: 1px solid #dc3545;
        border-radius: 10px;
        padding: 0.4rem 0.8rem;
        font-weight: bold;
        transition: 0.2s;
    }

    .btn-remove:hover {
        background-color: #dc3545;
        color: #fff;
    }
</style>

<div class="container mt-4">
    <div class="admin-header text-center">
        <h1 class="fw-bold mb-2"><i class="bi bi-people-fill me-2"></i>Gestión de Estudiantes</h1>
        <p class="opacity-75 mb-0">Supervisa el progreso y administra las matrículas de los alumnos.</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="accordion custom-accordion" id="accordionEstudiantes">

            @foreach (var estudiante in Model)
            {
                string collapseId = $"collapse-{estudiante.UsuarioID}";
                string headingId = $"heading-{estudiante.UsuarioID}";

                <div class="accordion-item">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed d-flex align-items-center gap-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">

                            @if (estudiante.Imagen != null && estudiante.Imagen.Length > 0)
                            {
                                string base64 = Convert.ToBase64String(estudiante.Imagen);
                                <img src="data:image/jpeg;base64,@base64" class="student-avatar" alt="Avatar" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle text-muted" style="font-size: 50px; line-height: 1;"></i>
                            }

                            <div>
                                <h5 class="mb-0 fw-bold">@estudiante.NombreUsuario</h5>
                                <small class="text-muted">@estudiante.CorreoElectronico</small>
                            </div>
                        </button>
                    </h2>

                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#accordionEstudiantes">
                        <div class="accordion-body p-0">

                            @if (estudiante.CursosInscritos != null && estudiante.CursosInscritos.Any())
                            {
                                <div class="p-3 bg-light border-bottom">
                                    <h6 class="fw-bold mb-0 text-muted"><i class="bi bi-journal-bookmark-fill me-2"></i>Cursos en curso:</h6>
                                </div>

                                @foreach (var curso in estudiante.CursosInscritos)
                                {
                                    <div class="course-list-item">
                                        <div>
                                            <span class="fw-bold d-block text-dark">@curso.Titulo</span>
                                            <div class="d-flex align-items-center gap-2">
                                                <small class="text-muted fw-bold">@curso.PorcentajeProgreso%</small>
                                                <div class="progress-mini">
                                                    <div class="progress-mini-fill" style="width: @curso.PorcentajeProgreso%;"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <button type="button" class="btn-remove" onclick="confirmarEliminacion(@estudiante.UsuarioID, @curso.CursoID, '@curso.Titulo', '@estudiante.NombreUsuario')">
                                            <i class="bi bi-trash3-fill"></i> Expulsar
                                        </button>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="p-4 text-center text-muted">
                                    <i class="bi bi-emoji-frown fs-3 d-block mb-2"></i>
                                    Este estudiante aún no se ha matriculado en ningún curso.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3 class="text-muted">No hay estudiantes registrados.</h3>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmarEliminacion(idUsuario, idCurso, nombreCurso, nombreEstudiante) {
            Swal.fire({
                title: '¿Estás seguro?',
                html: `Vas a expulsar a <b>${nombreEstudiante}</b> del curso <b>${nombreCurso}</b>.<br/>¡Esto borrará todo su progreso!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, expulsar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/Admin/ExpulsarEstudiante?idUsuario=${idUsuario}&idCurso=${idCurso}`;
                }
            })
        }
    </script>
}
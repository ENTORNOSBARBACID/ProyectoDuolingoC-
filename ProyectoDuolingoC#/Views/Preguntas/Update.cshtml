@model ProyectoDuolingoC_.Models.Pregunta

@{
    ViewData["Title"] = "Editar Pregunta";
    var opciones = ViewData["OPCIONES"] as List<ProyectoDuolingoC_.Models.OpcionRespuesta>;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332;
        --f-dark-shadow: #0d2219;
        --f-bg: #fdfdfd;
        --border-color: #e5e5e5;
        --input-bg: #f8f9fa;
        --f-selected-bg: #eef3f0;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
    }

    .update-wrapper {
        max-width: 700px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .form-card {
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 30px;
        padding: 3rem;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

    .page-title {
        color: var(--f-dark);
        font-weight: 900;
        font-size: 2.2rem;
        margin-bottom: 0.5rem;
        text-align: center;
    }

    .page-subtitle {
        text-align: center;
        color: #6c757d;
        margin-bottom: 2.5rem;
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 700;
        color: #3c3c3c;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control, .form-select {
        background-color: var(--input-bg);
        border: 2px solid var(--border-color);
        border-radius: 15px;
        padding: 1rem 1.2rem;
        font-size: 1rem;
        font-family: 'Outfit', sans-serif;
        color: #3c3c3c;
        transition: 0.2s;
        width: 100%;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--f-dark);
            background-color: white;
            outline: none;
            box-shadow: 0 0 0 4px rgba(26, 67, 50, 0.1);
        }

    /* --- TARJETAS PARA ELEGIR LA OPCIÓN CORRECTA --- */
    .opcion-card {
        display: flex;
        align-items: center;
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 15px;
        padding: 1rem 1.5rem;
        margin-bottom: 0.8rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #4b4b4b;
        cursor: pointer;
        transition: 0.2s;
    }

        .opcion-card:hover {
            background: #f7f7f7;
        }

        .opcion-card input[type="radio"] {
            display: none;
        }

            .opcion-card input[type="radio"]:checked + .opcion-texto {
                color: var(--f-dark);
            }

        .opcion-card:has(input[type="radio"]:checked) {
            border-color: var(--f-dark);
            background: var(--f-selected-bg);
        }

    .btn-save {
        background: var(--f-dark);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-weight: 800;
        font-size: 1.2rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.2);
        margin-top: 1.5rem;
        transition: 0.2s;
    }

        .btn-save:hover {
            transform: translateY(4px);
            box-shadow: 0 4px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.2);
        }

        .btn-save:active {
            transform: translateY(8px);
            box-shadow: 0 0 0 transparent;
        }

    .btn-back {
        color: #adb5bd;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1rem;
        transition: 0.2s;
    }

        .btn-back:hover {
            color: var(--f-dark);
            transform: translateX(-3px);
        }
</style>

<div class="update-wrapper">
    <div class="animate__animated animate__fadeInDown">
        <a asp-action="VerPreguntas" asp-route-idLec="@Model.LeccionID" class="btn-back">
            <i class="bi bi-arrow-left-short fs-4"></i> Volver a la lista
        </a>
    </div>

    <div class="form-card animate__animated animate__fadeInUp">
        <h1 class="page-title">Editar Pregunta</h1>
        <p class="page-subtitle">Modifica los detalles de esta pregunta.</p>

        <form asp-action="Update" method="post">
            <input type="hidden" asp-for="PreguntaID" />
            <input type="hidden" asp-for="LeccionID" />
            <input type="hidden" asp-for="TipoPregunta" /> <div class="form-group">
                <label asp-for="TextoPregunta" class="form-label">Enunciado de la pregunta</label>
                <textarea asp-for="TextoPregunta" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="TextoPregunta" class="text-danger small fw-bold"></span>
            </div>

            <div class="form-group">
                <label asp-for="PuntosXP" class="form-label">Puntos de Experiencia (XP)</label>
                <input asp-for="PuntosXP" type="number" class="form-control" min="5" step="5" required />
            </div>

            @if (Model.TipoPregunta == "CompletarCodigo")
            {
                <div class="form-group p-4" style="background: #f8f9fa; border-radius: 15px; border: 2px dashed #ced4da;">
                    <label asp-for="RespuestaCorrecta" class="form-label text-primary">
                        <i class="bi bi-code-square me-2"></i> Respuesta de Código
                    </label>
                    <textarea asp-for="RespuestaCorrecta" class="form-control mt-2" rows="2" required></textarea>
                    <small class="text-muted mt-2 d-block">Escribe exactamente el código que el alumno debe introducir para ganar.</small>
                </div>
            }
            else
            {
                <div class="form-group p-4" style="background: var(--f-selected-bg); border-radius: 15px; border: 2px dashed #a3bcae;">
                    <label class="form-label" style="color: var(--f-dark);">
                        <i class="bi bi-ui-checks me-2"></i> Selecciona la respuesta correcta:
                    </label>

                    @if (opciones != null && opciones.Any())
                    {
                        <div class="mt-3">
                            @foreach (var opcion in opciones)
                            {
                                <label class="opcion-card">
                                    <input type="radio" asp-for="OpcionCorrectaID" value="@opcion.OpcionID" required>
                                    <span class="opcion-texto">
                                        @opcion.TextoOpcion
                                    </span>
                                </label>
                            }
                        </div>
                        <a asp-action="VerOpciones" asp-route-id="@Model.PreguntaID" class="btn btn-sm btn-outline-success mt-2 fw-bold w-100">
                            <i class="bi bi-pencil-square"></i> Modificar textos de las opciones
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning fw-bold mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> No has creado opciones para esta pregunta todavía.
                            <br />
                            <a asp-action="VerOpciones" asp-route-id="@Model.PreguntaID" class="btn btn-warning btn-sm mt-2 fw-bold">Añadir opciones ahora</a>
                        </div>
                    }
                </div>
            }

            <button type="submit" class="btn-save">
                <i class="bi bi-floppy-fill me-2"></i> Guardar Cambios
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
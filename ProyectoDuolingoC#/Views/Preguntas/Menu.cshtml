@model IEnumerable<ProyectoDuolingoC_.Models.Pregunta>

@{
    ViewData["Title"] = "Preparación del Reto";

    // Calculamos los datos para mostrarlos en pantalla
    int totalPreguntas = Model?.Count() ?? 0;
    // Sumamos los puntos XP (si alguna pregunta es null, le asignamos 10 por defecto)
    int totalXP = Model?.Sum(p => p.PuntosXP) ?? 0;

    // Obtenemos el ID de la lección para el botón de volver y el de comenzar
    int leccionId = Model?.FirstOrDefault()?.LeccionID ?? 0;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332; /* El color verde oscuro que enviaste */
        --f-dark-shadow: #0d2219; /* Una sombra más oscura para el efecto 3D del botón */
        --f-bg: #fdfdfd;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
    }

    .btn-return {
        color: var(--f-dark);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        transition: 0.3s;
        margin-top: 2rem;
        margin-left: 2rem;
        opacity: 0.7;
    }

        .btn-return:hover {
            opacity: 1;
            transform: translateX(-5px);
        }

    /* --- TARJETA CENTRAL (LOBBY) --- */
    .lobby-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lobby-card {
        background: white;
        border-radius: 40px;
        padding: 4rem 3rem;
        box-shadow: 0 25px 50px rgba(0,0,0,0.08);
        border: 2px solid #f0f0f0;
        text-align: center;
        max-width: 500px;
        width: 100%;
    }

    .icon-wrapper {
        width: 120px;
        height: 120px;
        background: #eef3f0; /* Un fondo muy clarito basado en tu verde */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        color: var(--f-dark); /* El cohete en tu verde oscuro */
    }

    /* --- BADGES DE INFORMACIÓN --- */
    .stats-container {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin: 2.5rem 0;
    }

    .stat-badge {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        border-radius: 20px;
        padding: 1rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 120px;
    }

        .stat-badge i {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

    .stat-value {
        font-weight: 900;
        font-size: 1.2rem;
        color: var(--f-dark);
    }

    .stat-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* --- BOTÓN GIGANTE COMENZAR --- */
    .btn-start {
        background: var(--f-dark); /* Tu verde oscuro */
        color: white;
        border: none;
        border-radius: 25px;
        padding: 1.2rem 2rem;
        font-weight: 900;
        font-size: 1.4rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 10px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.4);
        transition: 0.2s;
        text-decoration: none;
        display: block;
        margin-top: 1rem;
    }

        .btn-start:hover {
            transform: translateY(5px);
            box-shadow: 0 5px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.4);
            color: white;
        }

        .btn-start:active {
            transform: translateY(10px);
            box-shadow: 0 0 0 var(--f-dark-shadow);
        }

    /* --- ENLACE SECUNDARIO (Ver Preguntas) --- */
    .btn-secondary-action {
        color: #adb5bd;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 1.5rem;
        transition: 0.2s;
        font-size: 0.95rem;
    }

        .btn-secondary-action:hover {
            color: var(--f-dark);
            transform: translateY(-2px);
        }
</style>

<a asp-controller="Lecciones" asp-action="Index" asp-route-id="@leccionId" class="btn-return animate__animated animate__fadeIn">
    <i class="bi bi-arrow-left-short fs-3"></i> Volver a la lección
</a>

<div class="container lobby-container">
    <div class="lobby-card animate__animated animate__zoomIn">

        <div class="icon-wrapper animate__animated animate__bounceIn" style="animation-delay: 0.3s;">
            <i class="bi bi-rocket-takeoff-fill" style="font-size: 4rem;"></i>
        </div>

        <h1 class="fw-bold mb-3" style="color: var(--f-dark);">¡Ponte a prueba!</h1>
        <p class="text-muted fs-5 mb-0">Demuestra lo que has aprendido en esta lección.</p>

        <div class="stats-container animate__animated animate__fadeInUp" style="animation-delay: 0.5s;">
            <div class="stat-badge">
                <i class="bi bi-ui-checks-grid text-primary"></i>
                <span class="stat-value">@totalPreguntas</span>
                <span class="stat-label">Preguntas</span>
            </div>
            <div class="stat-badge">
                <i class="bi bi-lightning-charge-fill text-warning"></i>
                <span class="stat-value">+@totalXP</span>
                <span class="stat-label">Puntos XP</span>
            </div>
        </div>

        @if (totalPreguntas > 0)
        {
            <a asp-action="Preguntas" asp-route-id="@leccionId" class="btn-start animate__animated animate__fadeInUp" style="animation-delay: 0.7s;">
                Empezar Reto
            </a>
        }
        else
        {
            <div class="alert alert-secondary mt-4 fw-bold" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i> No hay preguntas configuradas para esta lección todavía.
            </div>
        }

        <a asp-action="VerPreguntas" asp-route-idLec="@leccionId" class="btn-secondary-action animate__animated animate__fadeInUp" style="animation-delay: 0.9s;">
            <i class="bi bi-list-task"></i> Ver lista de preguntas
        </a>

    </div>
</div>
@model List<ProyectoDuolingoC_.Models.Pregunta>

@{
    ViewData["Title"] = "Lista de Preguntas";

    // Intentamos sacar el LeccionID de la primera pregunta.
    // Si la lista está vacía, idealmente deberías pasar el ViewData["LeccionID"] desde tu controlador.
    int? leccionId = ViewData["LeccionID"] as int?;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332; /* Tu verde bosque */
        --f-dark-shadow: #0d2219; /* Sombra para el botón 3D */
        --f-bg: #fdfdfd;
        --border-color: #e5e5e5;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
    }

    /* --- CONTENEDOR PRINCIPAL --- */
    .preguntas-wrapper {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .page-title {
        color: var(--f-dark);
        font-weight: 900;
        font-size: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    /* --- TARJETA DE PREGUNTA --- */
    .pregunta-card {
        display: flex;
        align-items: center;
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 20px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 1rem;
        text-decoration: none;
        color: #3c3c3c;
        transition: all 0.2s ease-in-out;
        gap: 1rem;
    }

        .pregunta-card:hover {
            border-color: var(--f-dark);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(26, 67, 50, 0.1);
            color: #3c3c3c;
        }

    /* --- ICONO Y CONTENIDO --- */
    .icon-circle {
        width: 50px;
        height: 50px;
        background: #eef3f0;
        color: var(--f-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .pregunta-info {
        flex-grow: 1;
        overflow: hidden;
    }

    .pregunta-titulo {
        font-weight: 800;
        font-size: 1.2rem;
        margin-bottom: 0.2rem;
        color: var(--f-dark);
    }

    .pregunta-texto {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #6c757d;
        font-size: 0.95rem;
        margin: 0;
    }

    .arrow-icon {
        color: #adb5bd;
        font-size: 1.5rem;
        transition: 0.2s;
    }

    .pregunta-card:hover .arrow-icon {
        color: var(--f-dark);
        transform: translateX(5px);
    }

    /* --- BOTÓN AÑADIR (Estilo 3D) --- */
    .btn-add {
        background: var(--f-dark);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-weight: 800;
        font-size: 1.2rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.2);
        text-decoration: none;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 2rem;
        transition: 0.2s;
    }

        .btn-add:hover {
            transform: translateY(4px);
            box-shadow: 0 4px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.2);
            color: white;
        }

        .btn-add:active {
            transform: translateY(8px);
            box-shadow: 0 0 0 transparent;
        }

    .btn-return {
        color: var(--f-dark);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        transition: 0.3s;
        margin-top: 2rem;
        margin-left: 2rem;
        opacity: 0.7;
    }

        .btn-return:hover {
            opacity: 1;
            transform: translateX(-5px);
        }
</style>

<div class="preguntas-wrapper">
    <h1 class="page-title animate__animated animate__fadeInDown">Gestión de Preguntas</h1><br />
    <div class="animate__animated animate__fadeInDown">
        <a asp-action="Menu" asp-route-id="@leccionId" class="btn-return animate__animated animate__fadeIn">
            <i class="bi bi-arrow-left-short fs-4"></i> Volver al menu
        </a>
    </div>

    <div class="preguntas-list">
        @if (Model != null && Model.Any())
        {
            int idx = 1;
            foreach (var pregunta in Model)
            {
                <a asp-action="Update" asp-route-id="@pregunta.PreguntaID" class="pregunta-card animate__animated animate__fadeInUp" style="animation-delay: @(idx * 0.1)s;">

                    <div class="icon-circle">
                        <i class="bi bi-patch-question-fill"></i>
                    </div>

                    <div class="pregunta-info">
                        <p class="pregunta-texto">@pregunta.TextoPregunta</p>
                    </div>

                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>

                idx++;
            }
        }
        else
        {
            <div class="alert alert-secondary text-center fw-bold mt-4" style="border-radius: 15px;">
                <i class="bi bi-info-circle me-2"></i> No hay preguntas registradas todavía.
            </div>
        }
    </div>

    <a asp-action="Create" asp-route-leccionId="@leccionId" class="btn-add animate__animated animate__fadeInUp" style="animation-delay: 0.5s;">
        <i class="bi bi-plus-circle-fill fs-4"></i> Añadir pregunta
    </a>

</div>
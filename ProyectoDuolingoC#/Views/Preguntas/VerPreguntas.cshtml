@model List<ProyectoDuolingoC_.Models.Pregunta>

@{
    ViewData["Title"] = "Lista de Preguntas";

    // Intentamos sacar el LeccionID de la primera pregunta.
    int? leccionId = Model?.FirstOrDefault()?.LeccionID ?? ViewData["LeccionID"] as int?;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --f-dark: #1a4332; /* Tu verde bosque */
        --f-dark-shadow: #0d2219; /* Sombra para el botón 3D */
        --f-bg: #fdfdfd;
        --border-color: #e5e5e5;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
    }

    /* --- CONTENEDOR PRINCIPAL --- */
    .preguntas-wrapper {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .page-title {
        color: var(--f-dark);
        font-weight: 900;
        font-size: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    /* --- TARJETA DE PREGUNTA (Ahora es un div) --- */
    .pregunta-card {
        display: flex;
        align-items: center;
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 20px;
        padding: 1rem 1.5rem;
        margin-bottom: 1rem;
        transition: all 0.2s ease-in-out;
        gap: 1rem;
    }

        .pregunta-card:hover {
            border-color: var(--f-dark);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(26, 67, 50, 0.1);
        }

    /* Enlace invisible para la parte de editar */
    .pregunta-edit-link {
        display: flex;
        align-items: center;
        flex-grow: 1;
        text-decoration: none;
        color: #3c3c3c;
        overflow: hidden;
        gap: 1rem;
    }

    /* --- ICONO Y CONTENIDO --- */
    .icon-circle {
        width: 50px;
        height: 50px;
        background: #eef3f0;
        color: var(--f-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .pregunta-info {
        flex-grow: 1;
        overflow: hidden;
    }

    .pregunta-texto {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #6c757d;
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0;
    }

    /* --- BOTÓN ELIMINAR PREGUNTA --- */
    .btn-delete-q {
        background: #fff0f0;
        color: #ff4b4b;
        border: none;
        border-radius: 12px;
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: 0.2s;
        cursor: pointer;
        flex-shrink: 0;
    }

        .btn-delete-q:hover {
            background: #ff4b4b;
            color: white;
            transform: scale(1.05);
        }

    /* --- BOTÓN AÑADIR (Estilo 3D) --- */
    .btn-add {
        background: var(--f-dark);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-weight: 800;
        font-size: 1.2rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.2);
        text-decoration: none;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 2rem;
        transition: 0.2s;
    }

        .btn-add:hover {
            transform: translateY(4px);
            box-shadow: 0 4px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.2);
            color: white;
        }

        .btn-add:active {
            transform: translateY(8px);
            box-shadow: 0 0 0 transparent;
        }

    .btn-return {
        color: #adb5bd;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        transition: 0.3s;
        margin-bottom: 2rem;
    }

        .btn-return:hover {
            color: var(--f-dark);
            transform: translateX(-5px);
        }
</style>

<div class="preguntas-wrapper">
    <div class="animate__animated animate__fadeInDown">
        <a asp-controller="Preguntas" asp-action="Menu" asp-route-id="@leccionId" class="btn-return">
            <i class="bi bi-arrow-left-short fs-3"></i> Volver al menú
        </a>
    </div>

    <h1 class="page-title animate__animated animate__fadeInDown">Gestión de Preguntas</h1>

    <div class="preguntas-list">
        @if (Model != null && Model.Any())
        {
            int idx = 1;
            foreach (var pregunta in Model)
            {
                <div class="pregunta-card animate__animated animate__fadeInUp" style="animation-delay: @(idx * 0.1)s;">

                    <a asp-action="Update" asp-route-id="@pregunta.PreguntaID" class="pregunta-edit-link" title="Editar pregunta">
                        <div class="icon-circle">
                            <i class="bi bi-patch-question-fill"></i>
                        </div>
                        <div class="pregunta-info">
                            <p class="pregunta-texto">@pregunta.TextoPregunta</p>
                        </div>
                    </a>

                    <form asp-action="Delete" method="post" onsubmit="confirmarBorradoPregunta(event, this)">
                        <input type="hidden" name="id" value="@pregunta.PreguntaID" />
                        <button type="submit" class="btn-delete-q" title="Borrar Pregunta">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </form>

                </div>
                idx++;
            }
        }
        else
        {
            <div class="alert alert-secondary text-center fw-bold mt-4" style="border-radius: 15px;">
                <i class="bi bi-info-circle me-2"></i> No hay preguntas registradas todavía.
            </div>
        }
    </div>

    <a asp-action="Create" asp-route-leccionId="@leccionId" class="btn-add animate__animated animate__fadeInUp" style="animation-delay: 0.5s;">
        <i class="bi bi-plus-circle-fill fs-4"></i> Añadir pregunta
    </a>

</div>

@section Scripts {
    <script>
        function confirmarBorradoPregunta(event, form) {
            event.preventDefault(); // Evitamos que se envíe de inmediato

            Swal.fire({
                title: '¿Estás seguro?',
                text: "Se eliminará esta pregunta y todas sus opciones. Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff4b4b',
                cancelButtonColor: '#1a4332',
                confirmButtonText: '<i class="bi bi-trash-fill me-1"></i> Sí, borrar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    popup: 'rounded-4'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }
    </script>
}
@model ProyectoDuolingoC_.Models.Leccion

@{
    ViewData["Title"] = "¡Reto Superado!";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332; /* Tu verde bosque */
        --f-dark-shadow: #0d2219; /* Sombra del botón 3D */
        --f-bg: #fdfdfd;
        --f-gold: #ffcb11; /* Dorado para el trofeo */
    }

    /* --- CONTENEDOR PRINCIPAL (Sustituye al body) --- */
    .victory-wrapper {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh; /* 80vh deja espacio para tu menú superior sin romperlo */
        padding: 2rem 0;
    }

    /* --- TARJETA DE VICTORIA --- */
    .victory-card {
        background: white;
        border-radius: 40px;
        padding: 4rem 3rem;
        text-align: center;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 25px 50px rgba(26, 67, 50, 0.1);
        border: 2px solid #eef3f0;
    }

    /* --- TROFEO --- */
    .icon-wrapper {
        width: 140px;
        height: 140px;
        background: #fff9e6; /* Fondo amarillo muy suave */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        color: var(--f-gold);
        box-shadow: 0 10px 25px rgba(255, 203, 17, 0.3);
    }

    /* --- ESTADÍSTICAS --- */
    .stat-badge {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        border-radius: 25px;
        padding: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-around;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .stat-value {
        font-weight: 900;
        font-size: 1.8rem;
        color: var(--f-dark); /* Texto en verde bosque */
    }

    .stat-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 0.2rem;
    }

    /* --- BOTÓN GIGANTE CONTINUAR --- */
    .btn-continue {
        background: var(--f-dark); /* Verde bosque */
        color: white;
        border: none;
        border-radius: 25px;
        padding: 1.2rem 2rem;
        font-weight: 900;
        font-size: 1.4rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 10px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.4);
        text-decoration: none;
        display: block;
        transition: 0.2s;
    }

        .btn-continue:hover {
            transform: translateY(5px);
            box-shadow: 0 5px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.4);
            color: white;
        }

        .btn-continue:active {
            transform: translateY(10px);
            box-shadow: 0 0 0 transparent;
        }
</style>

<div class="victory-wrapper">
    <div class="container px-4 d-flex justify-content-center">
        <div class="victory-card animate__animated animate__zoomIn">

            <div class="icon-wrapper animate__animated animate__tada" style="animation-delay: 0.3s;">
                <i class="bi bi-trophy-fill" style="font-size: 5rem;"></i>
            </div>

            <h1 class="fw-bold mb-2" style="color: var(--f-dark); font-size: 2.5rem;">¡Reto Superado!</h1>
            <p class="text-muted fs-5 mb-1">Has dominado la lección:</p>
            <p class="fw-bold fs-4 mb-0" style="color: var(--f-dark);">@Model.Titulo</p>

            <div class="stat-badge animate__animated animate__fadeInUp" style="animation-delay: 0.6s;">
                <div class="stat-item">
                    <i class="bi bi-lightning-charge-fill text-warning fs-3 mb-1"></i>
                    <span class="stat-value">@ViewData["Puntos"]</span>
                    <span class="stat-label">EXP Ganada</span>
                </div>
                <div class="stat-item">
                    <i class="bi bi-bullseye text-danger fs-3 mb-1"></i>
                    <span class="stat-value">@ViewData["Intentos"]</span>
                    <span class="stat-label">Intentos</span>
                </div>
            </div>

            <a asp-controller="Cursos" asp-action="Details" asp-route-id="@Model.CursoID" class="btn-continue animate__animated animate__fadeInUp" style="animation-delay: 0.9s;">
                Continuar
            </a>

        </div>
    </div>
</div>
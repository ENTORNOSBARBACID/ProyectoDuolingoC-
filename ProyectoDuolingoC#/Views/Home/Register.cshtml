@model ProyectoDuolingoC_.Models.Usuario

@{
    ViewData["Title"] = "Crear Cuenta";
    bool tieneImagen = Model.Imagen != null && Model.Imagen.Length > 0;
    string base64Image = "";
    if (tieneImagen)
    {
        base64Image = $"data:image/jpeg;base64,{Convert.ToBase64String(Model.Imagen)}";
    }
}

<style>
    .register-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }

    .register-card {
        background: white;
        border-radius: 30px;
        border: none;
        padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(26, 67, 50, 0.08);
        width: 100%;
        max-width: 550px;
    }

    .register-header h2 {
        font-weight: 800;
        color: var(--primary-dark);
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .register-header p {
        text-align: center;
        color: #777;
        margin-bottom: 2rem;
    }

    .form-label {
        font-weight: 700;
        color: var(--primary-dark);
        font-size: 0.85rem;
        margin-left: 5px;
        margin-bottom: 0.4rem;
    }

    .form-control, .form-select {
        border-radius: 15px;
        padding: 0.7rem 1.2rem;
        border: 2px solid #f0f0f0;
        background-color: #fcfcfc;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-dark);
            background-color: white;
            box-shadow: none;
        }

        /* Estilo especial para el input de archivo */
        .form-control[type="file"] {
            padding: 0.6rem;
        }

    .btn-register-submit {
        background-color: var(--primary-dark);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        margin-top: 1.5rem;
    }

        .btn-register-submit:hover {
            background-color: #2d6a4f;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(26, 67, 50, 0.2);
            color: white;
        }

    .login-link {
        color: var(--primary-dark);
        font-weight: 800;
        text-decoration: none;
    }

        .login-link:hover {
            text-decoration: underline;
        }
    /* --- ESTILOS DE SUBIDA DE IMAGEN --- */
    .image-upload-wrapper {
        border: 2px dashed #ced4da;
        border-radius: 15px;
        padding: 2rem;
        text-align: center;
        background-color: var(--input-bg);
        transition: 0.3s;
        cursor: pointer;
        position: relative;
    }

        .image-upload-wrapper:hover {
            border-color: var(--f-dark);
            background-color: var(--f-selected-bg);
        }

    .image-preview {
        max-width: 100%;
        max-height: 250px;
        border-radius: 10px;
        display: none;
        margin: 0 auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .upload-icon {
        font-size: 3rem;
        color: #adb5bd;
        margin-bottom: 1rem;
        transition: 0.3s;
    }

    .image-upload-wrapper:hover .upload-icon {
        color: var(--f-dark);
        transform: translateY(-5px);
    }
</style>

<div class="register-container">
    <div class="register-card">

        <div class="register-header">
            <h2>Únete a Languo</h2>
            <p>Empieza tu viaje hoy mismo, es gratis.</p>
        </div>

        @* IMPORTANTE: enctype para permitir subida de archivos *@
        <form asp-action="Register" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NombreUsuario" class="form-label">Nombre de Usuario</label>
                    <input asp-for="NombreUsuario" class="form-control" placeholder="Ej: JuanPerez" />
                    <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="CorreoElectronico" class="form-label">Email</label>
                    <input asp-for="CorreoElectronico" class="form-control" placeholder="correo@ejemplo.com" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Rol" class="form-label">Tu Perfil</label>
                    <select asp-for="Rol" class="form-select">
                        <option value="1">Estudiante</option>
                        <option value="2">Administrador</option>
                    </select>
                    <span asp-validation-for="Rol" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Contraseña</label>
                    <input name="pass" type="password" class="form-control" placeholder="••••••••" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-3">
                    <i class="bi bi-person-bounding-box me-2 text-muted"></i>Foto de Perfil
                </label>

                <div class="image-upload-wrapper" onclick="document.getElementById('imagenArchivo').click()">
                    @if (tieneImagen)
                    {
                        <i class="bi bi-cloud-arrow-up-fill upload-icon" id="uploadIcon" style="display: none;"></i>
                        <img id="preview" class="image-preview" src="@base64Image" style="display: block; border-radius: 50%; max-width: 180px; aspect-ratio: 1/1; object-fit: cover;" alt="Vista previa" />
                        <p class="mt-3 mb-0 fw-bold text-muted" id="uploadText">Haz clic para cambiar tu foto actual</p>
                    }
                    else
                    {
                        <i class="bi bi-cloud-arrow-up-fill upload-icon" id="uploadIcon"></i>
                        <img id="preview" class="image-preview" style="border-radius: 50%; max-width: 180px; aspect-ratio: 1/1; object-fit: cover;" alt="Vista previa" />
                        <p class="mt-3 mb-0 fw-bold text-muted" id="uploadText">Haz clic para subir una nueva foto</p>
                    }

                    <input type="file" id="imagenArchivo" name="archivoImagen" style="display: none;" accept="image/*" onchange="previewImage(event)" />
                </div>
                <small class="text-muted mt-2 d-block text-center">
                    <i class="bi bi-info-circle me-1"></i> Si no subes nada, se mantendrá tu avatar actual.
                </small>
            </div>

            <button type="submit" class="btn btn-register-submit w-100">
                Crear mi cuenta
            </button>
        </form>

        <div class="text-center mt-4">
            <span class="text-muted">¿Ya tienes cuenta?</span><br>
            <a asp-action="LogIn" class="login-link">Inicia sesión aquí</a>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        <script>
            // Script para mostrar la vista previa de la imagen seleccionada
            function previewImage(event) {
                var input = event.target;
                var reader = new FileReader();

                reader.onload = function(){
                    var dataURL = reader.result;
                    var preview = document.getElementById('preview');
                    var icon = document.getElementById('uploadIcon');
                    var text = document.getElementById('uploadText');

                    preview.src = dataURL;
                    preview.style.display = 'block';

                    // Ocultamos el icono y el texto original
                    icon.style.display = 'none';
                    text.textContent = 'Haz clic para cambiar la imagen';
                };

                if(input.files && input.files[0]){
                    reader.readAsDataURL(input.files[0]);
                }
            }
        </script>
    }
}
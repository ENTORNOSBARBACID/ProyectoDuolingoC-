@model IEnumerable<ProyectoDuolingoC_.Models.Curso>

@{
    ViewData["Title"] = "Catálogo de Cursos";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --forest-base: #1a4332;
        --forest-accent: #2d6a4f;
        --soft-gray: #f8f9fa;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: #f4f4f4;
    }

    /* --- CABECERA (HERO) --- */
    .header-hero {
        background: var(--forest-base);
        border-radius: 30px;
        padding: 4rem 2rem;
        color: white;
        text-align: center;
        margin-bottom: 3rem;
        box-shadow: 0 15px 35px rgba(26, 67, 50, 0.2);
    }

        .header-hero h1 {
            font-weight: 900;
            font-size: 3rem;
            margin-bottom: 1rem;
        }

    /* --- BUSCADOR --- */
    .search-container {
        max-width: 600px;
        margin: -55px auto 3rem;
    }

    .search-bar {
        background: white;
        border-radius: 20px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border: 2px solid transparent;
        transition: 0.3s;
    }

        .search-bar:focus-within {
            border-color: var(--forest-accent);
        }

        .search-bar input {
            border: none;
            width: 100%;
            margin-left: 10px;
            font-weight: 600;
            outline: none;
        }

    /* --- TARJETAS --- */
    .course-card {
        background: white;
        border-radius: 25px;
        padding: 2rem;
        border: none;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        border-bottom: 5px solid #e9ecef;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-bottom-color: var(--forest-accent);
        }

    /* --- TARJETA AÑADIR CURSO --- */
    .add-course-card {
        justify-content: center;
        align-items: center;
        text-align: center;
        border: 3px dashed #d1d5db; /* Borde discontinuo para indicar acción */
        background-color: transparent;
        color: inherit;
        text-decoration: none;
    }

        .add-course-card:hover {
            background-color: white;
            border-color: var(--forest-accent);
        }

        .add-course-card i {
            transition: transform 0.3s, color 0.3s;
        }

        .add-course-card:hover i {
            transform: scale(1.1);
            color: var(--forest-accent) !important;
        }

    .course-badge {
        background: #f0f7f4;
        color: var(--forest-base);
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .btn-action {
        background: var(--forest-base);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 0.8rem;
        font-weight: 700;
        width: 100%;
        margin-top: auto;
        text-decoration: none;
        display: block;
        text-align: center;
        transition: 0.3s;
    }

        .btn-action:hover {
            background: var(--forest-accent);
            color: white;
            transform: scale(1.02);
        }
    /* --- ICONOS DE ACCIÓN (EDITAR/BORRAR) --- */
    .action-icon {
        color: #adb5bd;
        transition: 0.2s ease-in-out;
        display: inline-flex;
    }

        .action-icon.edit:hover {
            color: var(--forest-accent); /* Tu verde bosque */
            transform: scale(1.15) translateY(-2px);
        }

        .action-icon.delete:hover {
            color: #ff4b4b; /* Rojo para borrar */
            transform: scale(1.15) translateY(-2px);
        }

    /* Corrección para Responsive en Razor (usar doble @@) */
    @@media (max-width: 768px) {
        .header-hero h1 {
            font-size: 2rem;
        }

        .course-card {
            padding: 1.5rem;
        }
    }
</style>

<div class="header-hero">
    <h1>Explora tus Cursos</h1>
    <p class="opacity-75 lead">Aprende programación paso a paso con rutas interactivas.</p>
</div>

<div class="search-container">
    <div class="search-bar">
        <i class="bi bi-search text-muted"></i>
        <input type="text" id="filterInput" placeholder="¿Qué quieres aprender hoy?">
    </div>
</div>

<div class="row g-4" id="courseGrid">
    @if (Model != null && Model.Any())
    {
        @foreach (var curso in Model)
        {
            <div class="col-md-6 col-lg-4 course-item">
                <div class="course-card">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="course-badge">@curso.EtiquetaLenguaje</span>

                        <div class="d-flex gap-2 align-items-center">

                            @* Mostramos los botones solo si el usuario logueado es Administrador (Rol 2) *@
                            @if (Context.User.IsInRole("2"))
                            {
                                <a asp-action="Update" asp-controller="Cursos" asp-route-id="@curso.CursoID" class="action-icon edit" title="Editar curso">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>
                                <a href="javascript:void(0)" onclick="confirmarBorrado('@Url.Action("Delete", "Cursos", new { id = curso.CursoID })')" class="action-icon delete" title="Eliminar curso">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </a>
                            }
                            else
                            {
                                /* Si es alumno, le seguimos mostrando el marcador decorativo */
                                <i class="bi bi-bookmark text-muted fs-5"></i>
                            }
                        </div>
                    </div>

                    <h3 class="fw-bold h4 mb-3">@curso.Titulo</h3>

                    <p class="text-muted small mb-4">
                        @(curso.Descripcion?.Length > 110 ? curso.Descripcion.Substring(0, 110) + "..." : curso.Descripcion)
                    </p>

                    <div class="d-flex gap-3 mb-4 small fw-bold text-muted">
                        <span><i class="bi bi-clock me-1"></i> 10h</span>
                        <span><i class="bi bi-star-fill text-warning me-1"></i> 4.8</span>
                    </div>

                    <a asp-action="Details" asp-controller="Cursos" asp-route-id="@curso.CursoID" class="btn-action">
                        VER CURSO
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-wind fs-1 text-muted"></i>
            <p class="text-muted mt-2">Vaya, parece que no hay cursos todavía...</p>
        </div>
    }
    @if (Context.User.IsInRole("2"))
    {
        
    <div class="col-md-6 col-lg-4">
        <a asp-action="Create" asp-controller="Cursos" class="course-card add-course-card">
            <i class="bi bi-plus-circle text-muted" style="font-size: 4rem; margin-bottom: 1rem;"></i>
            <h3 class="fw-bold h5 text-muted mb-0">Añadir nuevo curso</h3>
        </a>
    </div>
    }
</div>

@section Scripts {
    <script>
        // Buscador interactivo sin recarga
        document.getElementById('filterInput').addEventListener('input', function () {
            let filter = this.value.toLowerCase();
            let items = document.querySelectorAll('.course-item');

            items.forEach(item => {
                let text = item.innerText.toLowerCase();
                item.style.display = text.includes(filter) ? "block" : "none";
            });
        });
    
        function confirmarBorrado(urlDelete) {
            Swal.fire({
                title: '¿Estás completamente seguro?',
                text: "¡Peligro! Se borrarán todas las lecciones, preguntas y el progreso de los alumnos. Esta acción NO se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e63946', // Un rojo intenso para la acción destructiva
                cancelButtonColor: '#1a4332',  // Tu verde bosque para el botón seguro
                confirmButtonText: '<i class="bi bi-trash-fill me-1"></i> Sí, eliminar todo',
                cancelButtonText: 'Cancelar',
                customClass: {
                    popup: 'rounded-4'
                }
            });
        }
    </script>
}
@model ProyectoDuolingoC_.Models.Usuario

@{
    ViewData["Title"] = "Mi Perfil";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --f-dark: #1a4332; /* Tu verde bosque */
        --f-dark-shadow: #0d2219;
        --f-bg: #fdfdfd;
        --border-color: #e5e5e5;
        --f-selected-bg: #eef3f0;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--f-bg);
    }

    .profile-wrapper {
        max-width: 600px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    /* --- BOTÓN VOLVER --- */
    .btn-back {
        color: #adb5bd;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.5rem;
        transition: 0.2s;
    }

        .btn-back:hover {
            color: var(--f-dark);
            transform: translateX(-3px);
        }

    /* --- TARJETA PRINCIPAL --- */
    .profile-card {
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 35px;
        padding: 3rem 2rem;
        box-shadow: 0 15px 35px rgba(26, 67, 50, 0.05);
        text-align: center;
        position: relative;
    }

    /* --- AVATAR --- */
    .avatar-container {
        width: 130px;
        height: 130px;
        margin: 0 auto 1.5rem auto;
        border-radius: 50%;
        background-color: var(--f-selected-bg);
        border: 4px solid white;
        box-shadow: 0 8px 20px rgba(26, 67, 50, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-icon {
        font-size: 4rem;
        color: var(--f-dark);
    }

    /* --- INFO DEL USUARIO --- */
    .user-name {
        color: var(--f-dark);
        font-weight: 900;
        font-size: 2.2rem;
        margin-bottom: 0.2rem;
    }

    .user-email {
        color: #6c757d;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
    }

    /* --- MEDALLAS DE ROL --- */
    .role-badge {
        color: white;
        font-size: 0.85rem;
        font-weight: 800;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 2rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .badge-admin {
        background-color: var(--f-dark); /* Tu verde bosque para el jefe */
    }

    .badge-alumno {
        background-color: #6c757d; /* Un gris elegante para el alumno */
        /* Si prefieres que el alumno también sea verde, ponle: background-color: #2b7053; */
    }

    /* --- ESTADÍSTICAS (XP y Fecha) --- */
    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .stat-box {
        background: #f8f9fa;
        border: 2px solid var(--border-color);
        border-radius: 20px;
        padding: 1.5rem 1rem;
        transition: 0.2s;
    }

        .stat-box:hover {
            border-color: var(--f-dark);
            background: var(--f-selected-bg);
            transform: translateY(-3px);
        }

    .stat-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--f-dark);
        margin-bottom: 0.2rem;
    }

    .stat-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: #adb5bd;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* --- BOTONES DE ACCIÓN --- */
    .btn-edit {
        background: var(--f-dark);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-weight: 800;
        font-size: 1.2rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 0 var(--f-dark-shadow), 0 15px 20px rgba(26, 67, 50, 0.2);
        text-decoration: none;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        transition: 0.2s;
    }

        .btn-edit:hover {
            transform: translateY(4px);
            box-shadow: 0 4px 0 var(--f-dark-shadow), 0 10px 15px rgba(26, 67, 50, 0.2);
            color: white;
        }

        .btn-edit:active {
            transform: translateY(8px);
            box-shadow: 0 0 0 transparent;
        }
</style>

<div class="profile-wrapper">
    <div class="animate__animated animate__fadeInDown">
        <a asp-controller="Home" asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left-short fs-4"></i> Volver al inicio
        </a>
    </div>

    <div class="profile-card animate__animated animate__zoomIn">

        <div class="avatar-container">
            @if (Model.Imagen != null)
            {
                <img src="@Model.Imagen" alt="Foto de perfil" class="avatar-image" />
            }
            else
            {
                <i class="bi bi-person-fill avatar-icon"></i>
            }
        </div>

        <h1 class="user-name">@Model.NombreUsuario</h1>
        <p class="user-email">@Model.CorreoElectronico</p>

        @if (Model.Rol == 2)
        {
            <div class="role-badge badge-admin animate__animated animate__fadeIn">
                <i class="bi bi-shield-lock-fill me-1"></i> Administrador
            </div>
        }
        else if (Model.Rol == 1)
        {
            <div class="role-badge badge-alumno animate__animated animate__fadeIn">
                <i class="bi bi-mortarboard-fill me-1"></i> Alumno
            </div>
        }

        <div class="stats-grid">
            <div class="stat-box animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                <div class="stat-icon text-warning">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div class="stat-value">@Model.ExperienciaTotal</div>
                <div class="stat-label">Total XP</div>
            </div>

            <div class="stat-box animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
                <div class="stat-icon" style="color: var(--f-dark);">
                    <i class="bi bi-calendar-check-fill"></i>
                </div>
                <div class="stat-value fs-4 mt-2">@Model.FechaRegistro.ToString("MMM yyyy")</div>
                <div class="stat-label mt-1">Miembro desde</div>
            </div>
        </div>

        <div class="animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
            <a asp-action="EditPerfil" asp-route-id="@Model.UsuarioID" class="btn-edit">
                <i class="bi bi-pencil-square"></i> Editar Perfil
            </a>
        </div>

    </div>
</div>
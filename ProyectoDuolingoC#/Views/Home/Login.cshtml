@{
    ViewData["Title"] = "Iniciar Sesión";
}

<style>
    .login-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        background: white;
        border-radius: 30px;
        border: none;
        padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(26, 67, 50, 0.08);
        width: 100%;
        max-width: 450px;
    }

    .login-header h2 {
        font-weight: 800;
        color: var(--primary-dark);
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .login-header p {
        text-align: center;
        color: #777;
        margin-bottom: 2rem;
    }

    .form-label {
        font-weight: 700;
        color: var(--primary-dark);
        font-size: 0.9rem;
        margin-left: 5px;
    }

    .form-control {
        border-radius: 15px;
        padding: 0.8rem 1.2rem;
        border: 2px solid #f0f0f0;
        background-color: #fcfcfc;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: var(--primary-dark);
            background-color: white;
            box-shadow: none;
        }

    .btn-login-submit {
        background-color: var(--primary-dark);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 0.9rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

        .btn-login-submit:hover {
            background-color: #2d6a4f;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(26, 67, 50, 0.2);
            color: white;
        }

    .alert-forest {
        background-color: #fff2f2;
        border: none;
        border-left: 4px solid #dc3545;
        color: #dc3545;
        border-radius: 10px;
        font-weight: 600;
    }

    .register-link {
        color: var(--primary-dark);
        font-weight: 800;
        text-decoration: none;
    }

        .register-link:hover {
            text-decoration: underline;
        }
</style>

<div class="login-container">
    <div class="login-card">

        <div class="login-header">
            <h2>¡Hola de nuevo!</h2>
            <p>Continúa tu aprendizaje donde lo dejaste</p>
        </div>

        @if (ViewData["MENSAJE"] != null)
        {
            <div class="alert alert-forest alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
                @ViewData["MENSAJE"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Correo Electrónico</label>
                <input type="email" name="email" class="form-control" placeholder="nombre@ejemplo.com" required />
            </div>

            <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <input type="password" name="pass" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-login-submit w-100">
                Entrar a mi cuenta
            </button>
        </form>

        <div class="text-center mt-4">
            <span class="text-muted">¿Todavía no tienes cuenta?</span><br>
            <a asp-action="Register" class="register-link">Crea una ahora gratis</a>
        </div>

    </div>
</div>